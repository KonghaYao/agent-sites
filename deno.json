{
  "name": "agent-sites",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --allow-all --watch src/main.ts",
    "start": "deno run --allow-all --env-file=.env src/main.ts",
    "start:prod": "deno run --allow-all --cached-only src/main.ts",
    "check": "deno check 'src/**/*.ts'",
    "test": "deno test --allow-all 'src/**/*.ts'",
    "lint": "deno lint src/",
    "fmt": "deno fmt src/"
  },
  "imports": {
    "@std/": "jsr:@std/",
    "@std/assert/": "jsr:@std/assert@^1.0.5/",
    "@std/path/": "jsr:@std/path@^1.0.8/",
    "@std/media-types/": "jsr:@std/media-types@^1.0.5/",
    "@std/uuid/": "jsr:@std/uuid@^1.0.4/"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": false
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": false,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
